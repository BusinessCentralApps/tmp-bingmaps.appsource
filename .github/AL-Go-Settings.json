{
  "templateUrl": "https://github.com/businesscentralapps/tmptsn7Fg-AppSource@main",
  "$schema": "https://raw.githubusercontent.com/microsoft/AL-Go/Actions/54896140025c9a5238ea8217932bdb638e399041/.Modules/settings.schema.json",
  "AZURE_CREDENTIALSSecretName": "AZURE_CREDENTIALS",
  "versioningStrategy": 3,
  "unusedALGoSystemFiles": [
